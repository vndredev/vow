{
  "plansDirectory": "./.claude/plans",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/node_modules/.bin/vow hook",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/node_modules/.bin/vow hook session-start",
            "type": "command"
          }
        ],
        "matcher": "startup|clear|compact"
      }
    ]
  }
}
