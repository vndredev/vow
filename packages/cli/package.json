{
  "name": "@vow/cli",
  "version": "0.0.0",
  "private": true,
  "description": "vow's CLI (`vow`) — the dev lifecycle (run/status/logs/stop the apps) + the basics (check/build/test), one front door. The MCP is for LLMs; this is for people.",
  "bin": {
    "vow": "./src/cli.ts"
  },
  "type": "module",
  "exports": {
    ".": "./src/cli.ts",
    "./agent-prompts": "./src/agent-prompts.ts"
  },
  "scripts": {
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@vow/agent": "workspace:*",
    "@vow/core": "workspace:*",
    "@vow/mcp": "workspace:*",
    "@vow/observability": "workspace:*",
    "@vow/plan": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vite-plus": "catalog:"
  }
}
